# Required for `pnpm build:types` (dts-bundle-generator --external-inlines): pnpm's default
# symlinked node_modules layout (node_modules/discord.js-v13 -> .pnpm/discord.js@13.x/.../discord.js)
# breaks dts-bundle-generator's package-name matching for aliased devDependencies — it resolves
# the symlink and only ever sees the *real* package name ("discord.js"), never the alias, so
# --external-inlines discord.js-v13/discord.js-v14 silently does nothing (falls back to a plain,
# unresolved external import) instead of inlining. `hoisted` gives every package its own real
# directory under node_modules, like npm/yarn, which resolves correctly. Confirmed by reproducing
# and fixing this exact failure. Trade-off: hoisted linking is less strict than pnpm's default —
# phantom access to transitive (non-direct) dependencies becomes possible.
node-linker=hoisted
